# ─── Database ─────────────────────────────────────────────────────────────────
# MySQL connection string — update with your credentials
DATABASE_URL="mysql://root:yourpassword@localhost:3306/funddoo"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Primary frontend URL (required in production)
FRONTEND_URL=http://localhost:5173

# Extra comma-separated origins for preview/staging deployments (optional)
# EXTRA_ORIGINS=https://funddoo-preview.vercel.app,https://staging.funddoo.com
