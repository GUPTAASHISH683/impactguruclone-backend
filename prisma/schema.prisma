// ╔══════════════════════════════════════════════════╗
// ║  Funddoo - Prisma Schema (MySQL)                 ║
// ║  CMS-style: every visible word lives in the DB   ║
// ╚══════════════════════════════════════════════════╝

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Page {
  id          Int       @id @default(autoincrement())
  slug        String    @unique @db.VarChar(100)
  title       String    @db.VarChar(200)
  description String?   @db.Text
  isPublished Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  sections    Section[]
  metadata    Metadata?
  @@map("pages")
}

model Section {
  id          Int       @id @default(autoincrement())
  pageId      Int
  sectionKey  String    @db.VarChar(100)
  heading     String?   @db.VarChar(300)
  subheading  String?   @db.VarChar(300)
  body        String?   @db.Text
  tag         String?   @db.VarChar(100)
  isVisible   Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  page          Page           @relation(fields: [pageId], references: [id], onDelete: Cascade)
  contentBlocks ContentBlock[]
  @@unique([pageId, sectionKey])
  @@map("sections")
}

model ContentBlock {
  id         Int      @id @default(autoincrement())
  sectionId  Int
  blockKey   String   @db.VarChar(100)
  blockValue String   @db.Text
  blockType  String   @default("text")
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  @@unique([sectionId, blockKey])
  @@map("content_blocks")
}

model Navigation {
  id        Int      @id @default(autoincrement())
  location  String   @default("header") @db.VarChar(50)
  label     String   @db.VarChar(100)
  href      String   @db.VarChar(300)
  ariaLabel String?  @db.VarChar(300)
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  openInNew Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("navigation")
}

model FooterColumn {
  id        Int           @id @default(autoincrement())
  heading   String        @db.VarChar(100)
  sortOrder Int           @default(0)
  isVisible Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  links FooterLink[]
  @@map("footer_columns")
}

model FooterLink {
  id             Int          @id @default(autoincrement())
  footerColumnId Int
  label          String       @db.VarChar(200)
  href           String       @db.VarChar(300)
  sortOrder      Int          @default(0)
  openInNew      Boolean      @default(false)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  column FooterColumn @relation(fields: [footerColumnId], references: [id], onDelete: Cascade)
  @@map("footer_links")
}

model FooterSocial {
  id        Int      @id @default(autoincrement())
  label     String   @db.VarChar(200)
  glyph     String   @db.VarChar(20)
  href      String   @db.VarChar(300)
  platform  String   @db.VarChar(50)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("footer_socials")
}

model FooterMeta {
  id        Int      @id @default(autoincrement())
  metaKey   String   @unique @db.VarChar(100)
  metaValue String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("footer_meta")
}

model Campaign {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(300)
  slug        String   @unique @db.VarChar(300)
  description String   @db.Text
  category    String   @db.VarChar(50)
  label       String   @db.VarChar(100)
  raised      BigInt   @default(0)
  goal        BigInt
  donors      Int      @default(0)
  daysLeft    Int      @default(30)
  isUrgent    Boolean  @default(false)
  isActive    Boolean  @default(true)
  emoji       String?  @db.VarChar(10)
  bgGradient  String?  @db.VarChar(200)
  imagePath   String?  @db.VarChar(500)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([category])
  @@index([isActive])
  @@map("campaigns")
}

model Category {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @db.VarChar(50)
  label       String   @db.VarChar(100)
  emoji       String?  @db.VarChar(10)
  count       String   @db.VarChar(50)
  bgClass     String   @db.VarChar(100)
  borderClass String   @db.VarChar(100)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("categories")
}

model Testimonial {
  id         Int      @id @default(autoincrement())
  quote      String   @db.Text
  name       String   @db.VarChar(200)
  location   String   @db.VarChar(200)
  initials   String   @db.VarChar(5)
  colorClass String   @db.VarChar(100)
  rating     Int      @default(5)
  isActive   Boolean  @default(true)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@map("testimonials")
}

model Faq {
  id        Int      @id @default(autoincrement())
  question  String   @db.Text
  answer    String   @db.Text
  category  String?  @db.VarChar(100)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("faqs")
}

model Setting {
  id           Int      @id @default(autoincrement())
  settingGroup String   @default("general") @db.VarChar(100)
  settingKey   String   @db.VarChar(100)
  settingValue String   @db.Text
  settingType  String   @default("string")
  description  String?  @db.VarChar(300)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@unique([settingGroup, settingKey])
  @@map("settings")
}

model Metadata {
  id              Int      @id @default(autoincrement())
  pageId          Int      @unique
  metaTitle       String   @db.VarChar(200)
  metaDescription String?  @db.Text
  metaKeywords    String?  @db.Text
  ogTitle         String?  @db.VarChar(200)
  ogDescription   String?  @db.Text
  ogImage         String?  @db.VarChar(500)
  canonicalUrl    String?  @db.VarChar(500)
  robots          String   @default("index, follow") @db.VarChar(100)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
  @@map("metadata")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique @db.VarChar(255)
  name      String   @db.VarChar(200)
  password  String   @db.VarChar(255)
  role      String   @default("editor")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("users")
}
